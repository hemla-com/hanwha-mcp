{
  "name": "@hemla/hanwha-mcp",
  "version": "0.2.0",
  "description": "MCP server for configuring Hanwha Vision IP cameras via SUNAPI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hanwha-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "llms.txt"
  ],
  "keywords": [
    "mcp",
    "hanwha",
    "wisenet",
    "sunapi",
    "ip-camera"
  ],
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hemla-com/hanwha-mcp.git"
  },
  "homepage": "https://github.com/hemla-com/hanwha-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "digest-fetch": "^3.1.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
